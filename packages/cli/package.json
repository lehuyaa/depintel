{
  "name": "@lehuy/cli",
  "version": "0.1.0",
  "description": "CLI for depintel",
  "type": "module",
  "bin": {
    "depintel": "dist/index.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "dependencies": {
    "@lehuy/core": "workspace:*"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  }
}
